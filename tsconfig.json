{
    "compilerOptions": {
      "baseUrl": ".",
      "moduleResolution": "node",
      "noImplicitAny": false,
      "target": "es2019",
      "pretty": true,
      "module": "esnext",
      "sourceMap": true,
      "allowJs": true,
      "lib": [
        "dom",
        "es2019"
      ],
      "experimentalDecorators": true,
      "allowSyntheticDefaultImports": true,
      "esModuleInterop": true,
      "strict": false,
      "outDir": "./app",
      "typeRoots": [
        "node_modules/@types",
        "src/shared/types"
      ],
      "types": ["node"],
      "paths": {
        "@main": [
          "src/main"
        ],
        "@main/*": [
          "src/main/*"
        ],
        "@renderer": [
          "src/renderer"
        ],
        "@renderer/*": [
          "src/renderer/*"
        ],
        "@shareed": [
          "src/shared"
        ],
        "@shareed/*": [
          "src/shared/*"
        ]
      }
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
  }
