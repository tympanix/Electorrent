{
    "extends": "@tsconfig/node14/tsconfig.json",
    "include": [
        "./"
    ],
    "compilerOptions": {
        "baseUrl": "..",
        "lib": [
            "es6"
        ],
        "module": "esnext",
        "target": "es2020",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "forceConsistentCasingInFileNames": true,
        "types": [
            "node",
            "mocha",
            "chai",
            "chai-as-promised"
        ],
        "typeRoots": [
            "types",
            "../node_modules/@types",
            "../node_modules/webdriverio/types"
        ],
        "paths": {
            "@main": [
                "src/main"
            ],
            "@main/*": [
                "src/main/*"
            ],
            "@renderer": [
                "src/renderer"
            ],
            "@renderer/*": [
                "src/renderer/*"
            ],
            "@shared": [
                "src/shared"
            ],
            "@shared/*": [
                "src/shared/*"
            ],
            "@shareed": [
                "src/shared"
            ],
            "@shareed/*": [
                "src/shared/*"
            ]
        ]
    },
    "exclude": [
        "node_modules"
    ]
}
