{
  "name": "electorrent",
  "version": "2.14.0",
  "description": "A thin client for your torrenting needs",
  "type": "module",
  "main": "app/main.js",
  "license": "GPL-3.0",
  "scripts": {
    "app": "electron app/main.js",
    "app:debug": "NODE_ENV=test npm run app -- --force-title-bar-menu",
    "build": "npm run build:webpack",
    "build:webpack": "webpack --config webpack.config.js",
    "build:watch": "webpack --config webpack.config.js --watch",
    "postinstall": "electron-builder install-app-deps",
    "pack": "electron-builder --dir",
    "predist": "npm run build",
    "dist": "electron-builder --publish never",
    "prerelease": "npm run build",
    "release": "electron-builder",
    "version": "node ./scripts/sync-app-version.js && git add app/package.json",
    "test": "wdio run ./wdio.conf.ts",
    "smoketest": "npm test -- --client qbittorrent:latest --mochaOpts.grep \"torrent is stopped and resumed\"",
    "lint": "eslint --ext .ts ./src ./test ./wdio.conf.ts && tsc --build"
  },
  "keywords": [
    "utorrent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tympanix/Electorrent.git"
  },
  "author": "tympanix",
  "dependencies": {
    "electron-regedit": "^2.0.0",
    "geoip-country": "^5.0.202607180103",
    "less": "^4.4.1",
    "q": "^1.5.1",
    "winreg": "^1.2.2"
  },
  "devDependencies": {
    "@electorrent/xmlrpc": "^1.5.0",
    "@fontsource/lato": "^5.2.7",
    "@types/angular": "^1.5.8",
    "@types/angular-animate": "^1.5.10",
    "@types/angular-resource": "^1.5.16",
    "@types/axios": "^0.14.0",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^7.1.5",
    "@types/form-data": "^2.5.0",
    "@types/jquery": "^3.5.5",
    "@types/magnet-uri": "^5.1.3",
    "@types/mocha": "^10.0.4",
    "@types/moment": "^2.13.0",
    "@types/mousetrap": "^1.6.5",
    "@types/node": "^14.18.16",
    "@types/parse-torrent": "^5.8.4",
    "@types/qs": "^6.9.7",
    "@types/tapable": "^0.2.5",
    "@types/underscore": "^1.10.24",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@wdio/cli": "^9.23.3",
    "@wdio/electron-service": "^10.0.0",
    "@wdio/electron-types": "^9.2.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "@wdio/types": "^9.27.1",
    "angular": "^1.8.2",
    "angular-animate": "^1.8.2",
    "angular-marked": "^1.2.2",
    "angular-resource": "^1.8.2",
    "angular-table-resize": "^3.0.0",
    "angular-ui-sortable": "^0.19.0",
    "axios": "^1.18.1",
    "base64-js": "^1.2.0",
    "chai": "^4.2.0",
    "chai-as-promised": "^7.1.1",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "docker-compose": "^1.3.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
